# MOECISH 環境變數範本
# 1. cp .env.example .env
# 2. 修改 NEXTAUTH_SECRET 為隨機字串（正式環境請用 openssl rand -hex 32）
# 3. 其他留預設即可開發

# SQLite 開發用；正式環境可改為 PostgreSQL 連線字串，schema.prisma 的 provider 也要改
DATABASE_URL="file:./dev.db"

# Session 簽章密鑰；開發可隨便打，正式請用強隨機值
NEXTAUTH_SECRET="change-me-to-a-random-string"

# Next.js URL，本機開發保持此值
NEXTAUTH_URL="http://localhost:3000"

# 佐證與簽章檔案儲存根目錄（相對路徑或絕對路徑）
STORAGE_DIR="./uploads"

# 可選：自訂檢核表 ODT 路徑；留白則使用 prisma/seeds/checklist-115.odt
# CHECKLIST_ODT=""
